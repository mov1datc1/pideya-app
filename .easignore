# EAS Build ignore file — same as .gitignore but INCLUDES .env
# so that environment variables are available during build

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# NOTE: .env is NOT ignored for EAS builds
# .env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Other projects inside this repo
pideya-driver/
rancho_eats_App.tsx
rancho_eats_rebrand.patch
